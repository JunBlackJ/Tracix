{
  "name": "tracix-server",
  "version": "1.0.0",
  "description": "Tracix IT Governance Platform - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npx tsc",
    "start": "prisma db push && node dist/index.js",
