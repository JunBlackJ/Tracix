generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                        String   @id
  name                      String
  logo_url                  String   @default("")
  plan                      String   @default("free")
  plan_expires_at           DateTime?
  max_admin_per_platform    Int      @default(3)
  access_review_delay_days  Int      @default(90)
  subscription_alert_days   Int      @default(30)
  enabled_modules           Json     @default("[\"habilitations\",\"membres\",\"plateformes\",\"score-de-risque\",\"abonnements\",\"alertes\",\"journal\",\"rapports\",\"import\"]")
  alert_email_enabled       Boolean  @default(false)
  alert_email_address       String   @default("")
  alert_email_frequency     String   @default("daily")
  is_suspended              Boolean  @default(false)
  onboarding_completed      Boolean  @default(false)
  created_at                DateTime @default(now())

  users             UserApp[]
  userOrganizations UserOrganization[]
  invitations       Invitation[]
  platforms     Platform[]
  members       Member[]
  accessRights  AccessRight[]
  systems       System[]
  networkFlows  NetworkFlow[]
  subscriptions Subscription[]
  alerts        Alert[]
  auditTrails   AuditTrail[]
  riskSnapshots RiskSnapshot[]
  categories    Category[]
  customModules    CustomModule[]
  reviewCampaigns  ReviewCampaign[]
  samlConfig       SamlConfig?

  @@map("organizations")
}

model UserApp {
  id              String   @id
  organization_id String
  full_name       String
  email           String   @unique
  password_hash   String?
  oauth_provider  String?
  oauth_id        String?
  totp_secret            String?
  totp_enabled           Boolean  @default(false)
  role                   String   @default("viewer")
  is_superadmin          Boolean  @default(false)
  failed_login_attempts  Int      @default(0)
  locked_until           DateTime?
  last_login_at          DateTime @default(now())
  created_at             DateTime @default(now())

  organization        Organization         @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  userOrganizations   UserOrganization[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]

  @@map("users")
}

model UserOrganization {
  id              String   @id
  user_id         String
  organization_id String
  role            String   @default("admin")
  joined_at       DateTime @default(now())

  user         UserApp      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([user_id, organization_id])
  @@map("user_organizations")
}

model Platform {
  id                String   @id
  organization_id   String
  name              String
  category          String   @default("")
  access_type       String   @default("")
  url               String   @default("")
  auth_method       String   @default("")
  has_mfa           Boolean  @default(false)
  environment       String   @default("production")
  responsible       String   @default("")
  target_population String   @default("")
  sla               String   @default("")
  status            String   @default("actif")
  last_check_date   String   @default("")
  notes             String   @default("")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  organization Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  accessRights AccessRight[]

  @@map("platforms")
}

model Member {
  id              String   @id
  organization_id String
  full_name       String
  username        String
  team            String   @default("")
  account_type    String   @default("nominatif")
  status          String   @default("actif")
  email           String
  departure_date  String?
  risk_score      Int      @default(50)
  risk_factors    Json     @default("[]")
  notes           String   @default("")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  accessRights AccessRight[]

  @@unique([organization_id, email])
  @@unique([organization_id, username])
  @@map("members")
}

model AccessRight {
  id               String   @id
  organization_id  String
  member_id        String
  platform_id      String
  level            String   @default("none")
  granted_at       String   @default("")
  granted_by       String   @default("")
  last_review_date String   @default("")
  next_review_date String   @default("")
  reviewed_by      String   @default("")
  notes            String   @default("")

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  member       Member       @relation(fields: [member_id], references: [id], onDelete: Cascade)
  platform     Platform     @relation(fields: [platform_id], references: [id], onDelete: Cascade)

  @@unique([member_id, platform_id])
  @@map("access_rights")
}

model System {
  id                 String   @id
  organization_id    String
  system_id          String
  hostname           String
  type               String   @default("")
  environment        String   @default("production")
  os_version         String   @default("")
  ip_address         String   @default("")
  vlan               String   @default("")
  location           String   @default("")
  role_usage         String   @default("")
  owner              String   @default("")
  tech_responsible   String   @default("")
  criticality        String   @default("normale")
  status             String   @default("actif")
  deployment_date    String   @default("")
  end_of_support_date String  @default("")
  backup_policy      String   @default("")
  last_patch_date    String   @default("")
  notes              String   @default("")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("systems")
}

model NetworkFlow {
  id                String   @id
  organization_id   String
  flow_id           String
  source_host       String   @default("")
  source_zone       String   @default("")
  destination_host  String   @default("")
  destination_zone  String   @default("")
  port              String   @default("")
  protocol          String   @default("")
  service           String   @default("")
  direction         String   @default("entrant")
  status            String   @default("autorisé")
  firewall_rule     String   @default("")
  justification     String   @default("")
  responsible       String   @default("")
  last_review_date  String   @default("")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("network_flows")
}

model Subscription {
  id              String   @id
  organization_id String
  name            String
  category        String   @default("")
  vendor          String   @default("")
  cost_monthly    Float    @default(0)
  cost_annual     Float    @default(0)
  cost_weekly     Float    @default(0)
  currency        String   @default("EUR")
  billing_cycle   String   @default("mensuel")
  renewal_date    String   @default("")
  auto_renew      Boolean  @default(false)
  responsible     String   @default("")
  status          String   @default("actif")
  contract_url    String   @default("")
  notes           String   @default("")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model PromoCode {
  id         String    @id
  code       String    @unique
  months     Int       @default(1)
  max_uses   Int       @default(1)
  uses       Int       @default(0)
  created_at DateTime  @default(now())
  expires_at DateTime?

  @@map("promo_codes")
}

model Category {
  id              String   @id
  organization_id String
  type            String   // 'subscription' | 'platform' | 'team'
  label           String
  color           String   @default("#6B7280")
  created_at      DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, type, label])
  @@map("categories")
}

// ─── Modules personnalisés ───
// module_type controls the UI layout rendered on the frontend.
// Supported types: 'liste' | 'contacts' | 'documents' | 'procedures' | 'notes' | 'kpis'
model CustomModule {
  id              String   @id
  organization_id String
  title           String
  description     String   @default("")
  module_type     String   @default("liste")   // controls UI layout
  icon            String   @default("Layers")  // lucide icon name
  color           String   @default("#534AB7")
  nav_order       Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization    @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  entries      CustomEntry[]

  @@map("custom_modules")
}

model CustomEntry {
  id        String   @id
  module_id String
  data      Json     @default("{}")   // flexible key-value per module_type
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  module CustomModule @relation(fields: [module_id], references: [id], onDelete: Cascade)

  @@map("custom_entries")
}

model Invitation {
  id              String    @id
  organization_id String
  created_by      String
  email           String?
  role            String    @default("viewer")
  token           String    @unique
  expires_at      DateTime
  accepted_at     DateTime?
  accepted_by     String?
  created_at      DateTime  @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Alert {
  id              String   @id
  organization_id String
  source_module   String
  source_id       String
  source_label    String   @default("")
  type            String
  severity        String   @default("info")
  message         String
  is_resolved     Boolean  @default(false)
  resolved_by     String   @default("")
  resolved_at     String   @default("")
  created_at      DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("alerts")
}

// ─── Campagnes de revue d'accès ───
model ReviewCampaign {
  id              String   @id
  organization_id String
  name            String
  description     String   @default("")
  status          String   @default("active")  // active | completed | cancelled
  created_by      String
  due_date        String   @default("")
  completed_at    DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization    @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  items        ReviewItem[]

  @@map("review_campaigns")
}

model ReviewItem {
  id              String   @id
  campaign_id     String
  organization_id String
  member_id       String
  platform_id     String
  access_right_id String
  original_level  String
  decision        String   @default("pending")  // pending | confirmed | revoked | modified
  new_level       String   @default("")
  comment         String   @default("")
  reviewed_by     String   @default("")
  reviewed_at     DateTime?
  created_at      DateTime @default(now())

  campaign ReviewCampaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@map("review_items")
}

model SamlConfig {
  id              String   @id
  organization_id String   @unique
  entity_id       String
  sso_url         String
  certificate     String
  is_enabled      Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("saml_configs")
}

model RiskSnapshot {
  id              String   @id
  organization_id String
  date            String   // YYYY-MM-DD
  avg_score       Float
  count_critical  Int      @default(0)
  count_high      Int      @default(0)
  count_medium    Int      @default(0)
  count_low       Int      @default(0)
  member_count    Int      @default(0)
  created_at      DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, date])
  @@map("risk_snapshots")
}

// Singleton row (id = "global") to store super-admin MFA config
model AdminConfig {
  id          String  @id @default("global")
  totp_secret String? // null = MFA disabled
  totp_enabled Boolean @default(false)

  @@map("admin_config")
}

model PasswordResetToken {
  id         String    @id
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user UserApp @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model RefreshToken {
  id         String   @id
  user_id    String
  token_hash String   @unique
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())

  user UserApp @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model AuditTrail {
  id              String   @id
  organization_id String
  actor           String
  action          String
  target_type     String   @default("")
  target_id       String   @default("")
  target_label    String   @default("")
  old_value       Json     @default("{}")
  new_value       Json     @default("{}")
  ip_address      String   @default("")
  user_agent      String   @default("")
  created_at      DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("audit_trails")
}
